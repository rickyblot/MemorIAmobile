# Copy to apps/web/.env and restart `npm run dev` (Vite only reads .env on startup).

# API proxy (Express)
API_PROXY_TARGET=http://127.0.0.1:3001

# Hostinger Ecommerce (required for /plans + Subscribe checkout)
# Same Store ID as apps/api ECOMMERCE_STORE_ID — get from Hostinger Ecommerce.
VITE_ECOMMERCE_API_URL=https://api-ecommerce.hostinger.com
VITE_ECOMMERCE_STORE_ID=

# Auth and data go through /hcgi/api (no PocketBase).
# Google OAuth redirects back to the web app with ?token=...
