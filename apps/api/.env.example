# Copy to apps/api/.env

# --- Server ---
PORT=3001
CORS_ORIGIN=*
NODE_ENV=development
API_PUBLIC_URL=http://127.0.0.1:3001
WEB_APP_URL=http://127.0.0.1:3000

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- MySQL (Hostinger or local) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=memoriamobile
# Optional on Hostinger if auto-detect fails:
# MYSQL_SOCKET=/var/run/mysqld/mysqld.sock

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3001/auth/oauth/google/callback

# --- Apple Sign In (optional; needs Apple Developer account) ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Path to .p8 key file OR paste key with \n newlines
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://127.0.0.1:3001/auth/oauth/apple/callback

# --- Hostinger website / proxy ---
WEBSITE_DOMAIN=www.memoriamobile.com
WEBSITE_ID=
PROXY_ENTRANCE_ID=

# --- Hostinger Ecommerce / Stripe subscriptions ---
# Required for listing a user's subscription + billing portal after checkout.
# Store ID is also exposed to the SPA via GET /ecommerce/config (runtime-safe on Hostinger).
# Optionally set VITE_ECOMMERCE_STORE_ID in apps/web/.env for local Vite-only builds.
ECOMMERCE_API_URL=https://api-ecommerce.hostinger.com
ECOMMERCE_STORE_ID=
ECOMMERCE_API_KEY=

# --- Hostinger Integrated AI ---
INTEGRATED_AI_API_URL=
INTEGRATED_AI_API_KEY=

# --- Amazon S3 (user media: photos / videos / AI images) ---
# When all three of S3_BUCKET + AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY are set,
# new uploads go to S3 instead of local disk. Leave blank to keep local uploads.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Optional: CloudFront or public bucket base URL (no trailing slash).
# If set, file URLs point here directly. If omitted, /uploads/* redirects to a signed S3 URL.
# S3_PUBLIC_BASE_URL=https://dxxxxx.cloudfront.net

