{
  "name": "memoriamobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "main": "server.js",
  "scripts": {
    "dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/api\"",
    "prebuild": "npm install --prefix apps/api --include=dev && npm install --prefix apps/web --include=dev",
    "build": "npm run build --prefix apps/web",
    "start": "node server.js",
    "migrate": "npm run migrate --prefix apps/api",
    "lint": "concurrently --raw \"npm run lint --prefix apps/web\" \"npm run lint --prefix apps/api\"",
    "horizons:diff": "node scripts/horizons-sync-diff.mjs",
    "package:hostinger": "node scripts/package-hostinger-zip.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.6",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
